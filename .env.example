# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Model (isteğe bağlı, varsayılan: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890           # Varsayılan kanal
TELEGRAM_VIP_CHAT_ID=                     # VIP kanal (isteğe bağlı)
TELEGRAM_PUBLIC_CHAT_ID=                  # Public/duyuru kanalı (isteğe bağlı)

# TradingView Otomatik Tarama
TV_SYMBOL=BINANCE:BTCUSDT.P
TV_CHART_ID=                              # TradingView chart ID (boş = yeni chart)

# Webhook Sunucusu (python webhook_server.py)
WEBHOOK_PORT=8080
WEBHOOK_AUTO_TELEGRAM=false               # true = alert gelince otomatik Telegram bildir
WEBHOOK_GATE_CHANNEL=VIP                  # 5M BULL/BEAR GATE sinyalleri → bu kanala gider
WEBHOOK_BIAS_CHANNEL=Public               # 4H HTF/CHoCH sinyalleri → bu kanala gider
PIPELINE_AUTO=false                       # true = GATE sinyalinde otomatik screenshot + AI analiz başlat
